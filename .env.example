# Copy to .env (gitignored) and fill in real values.
# Host-side port bindings (all 127.0.0.1-only); override if the default is taken.
# RABBITMQ_PORT=5672
# RABBITMQ_MGMT_PORT=15672
# POSTGRES_PORT=5432

RABBITMQ_USER=airadar
RABBITMQ_PASSWORD=change-me
POSTGRES_DB=airadar
POSTGRES_USER=airadar
POSTGRES_PASSWORD=change-me

# LLM (digester) — provider behind LlmClient; "fake" runs the pipeline free
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Higher quality (gemini-2.5-pro) for the daily high-value set; set the matching
# per-Mtok costs so the budget ledger stays accurate. Flash defaults: 0.30/2.50.
# GEMINI_MODEL=gemini-2.5-pro
# LLM_INPUT_USD_PER_MTOK=1.25
# LLM_OUTPUT_USD_PER_MTOK=10.00
DAILY_LLM_BUDGET_USD=0.50
# Digest at most this many (highest-value) items per UTC day; 0 = unlimited.
# The primary volume/cost cap — excess items re-park until the next day.
# DAILY_DIGEST_LIMIT=10
# News older than this many days is dropped to STALE before any spend (V5):
# the daily cap is FIFO, so without this a backlog starves fresh news and we'd
# comment on week-old items. Clock is published_at, else received_at. 0 = off.
# MATCH_MAX_AGE_DAYS=3
# Unacked messages held per consumer. Raising it does NOT let the daily cap or
# budget check be raced: the amqp-client dispatches one channel's deliveries
# sequentially, so a single digester checks the cap and digests one item at a
# time. Running two digesters WOULD race it — the cap has no DB-level guard.
# PREFETCH=8

# Resonance gate (matcher, ADR-010): news is embedded against the book library
# BEFORE any LLM spend. Nearest-book cosine distance beyond the threshold parks
# the item in NO_RESONANCE, terminal. Thresholds calibrated by the spike report
# (book-library-hub/docs/news-echo-spike-report.md).
# LIBRARY_PROVIDER=bridge            # "fake" runs the pipeline without the bridge
# LIBRARY_URL=http://library-bridge:7788
LIBRARY_SECRET=
# MATCH_NO_RESONANCE_DISTANCE=1.10
# MATCH_QUERY_CHARS=1500

# Daily essay (essayist): the strongest-resonance shortlist pick becomes the
# day's book-informed commentary. The model may decline (寧缺勿濫) — days
# without an essay are expected.
# ESSAY_MODEL=gemini-2.5-pro
# ESSAY_INPUT_USD_PER_MTOK=1.25
# ESSAY_OUTPUT_USD_PER_MTOK=10.00
# ESSAY_HOUR_UTC=22
# ESSAY_MAX_CHAPTERS=2
# Relevance judge between curator and essayist: vector distance measures
# library density, not relatedness (ADR-010 amendment) — an LLM verdict gates
# each pick before any essay money is spent. Its own tier on purpose: a
# deployment may run GEMINI_MODEL on pro for digest quality, but a yes/no
# verdict must stay cheap. At most ESSAY_JUDGE_MAX_CANDIDATES verdicts/day.
# JUDGE_MODEL=gemini-2.5-flash
# JUDGE_INPUT_USD_PER_MTOK=0.30
# JUDGE_OUTPUT_USD_PER_MTOK=2.50
# ESSAY_JUDGE_MAX_CANDIDATES=3

# Selection (curator, ADR-009): once per UTC day after SELECT_HOUR_UTC the
# digester ranks the day's digests RELATIVE to each other with a stronger model
# and shortlists at most SHORTLIST_MAX_PER_DAY items for the book-informed
# daily commentary (M6). Costs land in the same daily budget above.
# SELECT_MODEL=gemini-2.5-pro
# SELECT_INPUT_USD_PER_MTOK=1.25
# SELECT_OUTPUT_USD_PER_MTOK=10.00
# SELECT_HOUR_UTC=21
# SELECT_MIN_SCORE=3
# SHORTLIST_MAX_PER_DAY=3
# Uncomposed picks older than this drop out of the pool — news goes stale.
# SHORTLIST_TTL_DAYS=7
# CURATOR_TICK_MINUTES=5

# Publisher — plain output dir; the site-publisher sidecar owns the git push
# CONTENT_DIR=out/content
# PUBLISH_DIGEST=false                 # digest pages retired 2026-07-18; essays only.
#                                      # true resurrects daily/weekly markdown.

# site-publisher: push token for the bookshelf-echo-site repo (contents: write)
SITE_GIT_TOKEN=

# Producers (intervals in minutes; defaults: hn 60, blogs 240, guardian/news 180, others 1440)
# SOURCES=guardian                     # default; the essay wants deep journalism only.
#                                      # hn/arxiv/gh-trending/blogs/news still exist, re-enable here.
GUARDIAN_API_KEY=                      # REQUIRED for the guardian source (free: open-platform.theguardian.com)
# GUARDIAN_QUERIES=tag=news/series/the-long-read,section=commentisfree
# GUARDIAN_PAGE_SIZE=10

# Essay quality gate (critic reviews every draft; fail → one revision, fail again → no essay)
# CRITIC_MODEL=gemini-2.5-flash
# CRITIC_INPUT_USD_PER_MTOK=0.30
# CRITIC_OUTPUT_USD_PER_MTOK=2.50
# BLOG_MAX_PER_FEED=20
# HN_QUERY=LLM
# HN_MIN_POINTS=30
# HN_INTERVAL_MINUTES=60
# ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG
# ARXIV_MAX_RESULTS=30
# GH_TRENDING_QUERY=topic:llm
# GH_TRENDING_WINDOW_DAYS=7
# BLOG_FEEDS=https://openai.com/news/rss.xml,https://huggingface.co/blog/feed.xml,https://simonwillison.net/atom/everything/
# REDDIT_SUBREDDITS=MachineLearning+LocalLLaMA
# REDDIT_LIMIT=25

# Metrics (127.0.0.1-only; per-app defaults 9101-9104, 0 disables)
# METRICS_PORT=
# SNAPSHOT_INTERVAL_MINUTES=60
# Grace before the first snapshot, so a deploy that restarts the whole stack does
# not record its siblings as consumer-less for a whole interval. 0 in tests.
# SNAPSHOT_SETTLE_SECONDS=45
