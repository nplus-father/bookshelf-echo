[Unit]
Description=ai-radar producers
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/workspace/ai-radar
EnvironmentFile=%h/workspace/ai-radar/.env
ExecStart=%h/workspace/ai-radar/producers/build/install/producers/bin/producers
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
